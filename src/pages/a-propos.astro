---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="À propos — Wisdom MUONAKA"
  description="Parcours, expérience et formation de Wisdom MUONAKA, ingénieur DevOps"
>
  <div class="max-w-4xl mx-auto px-6 py-20">

    <!-- Page header -->
    <div class="mb-16">
      <p class="label mb-3">À propos</p>
      <h1 class="text-4xl font-bold text-white mb-8">Wisdom MUONAKA</h1>
      <div class="space-y-4 text-gray-300 leading-relaxed text-[15px] max-w-2xl">
        <p>
          Passionné par l'intersection entre le développement logiciel, l'infrastructure et
          l'architecture systèmes, je construis des systèmes fiables, scalables et observables.
          Mon approche est orientée SRE : automatiser, mesurer, optimiser et améliorer en continu.
        </p>
        <p>
          Étudiant ingénieur à l'ISTY Paris-Saclay (Bac+4), je combine une solide formation
          en informatique avec une pratique intensive des outils DevOps modernes — de Terraform
          à Prometheus en passant par les pipelines CI/CD.
        </p>
      </div>
    </div>

    <!-- ── EXPÉRIENCE PROFESSIONNELLE ── -->
    <section class="mb-16">
      <h2 class="section-heading">Expérience professionnelle</h2>

      <div class="card card-blue">
        <div class="flex flex-wrap items-start justify-between gap-4 mb-5">
          <div>
            <h3 class="font-bold text-white text-lg">Développeur Full-Stack — Stage</h3>
            <p class="text-sky-400 text-sm font-medium mt-1">VBN-IT, Paris</p>
          </div>
          <span class="mono text-xs text-gray-500 bg-white/5 px-3 py-1.5 rounded-full whitespace-nowrap">
            Juin – Août 2025
          </span>
        </div>

        <ul class="space-y-2.5 mb-5">
          {[
            "Développement de composants React.js réutilisables pour une application B2B.",
            "Intégration d'APIs RESTful FastAPI/Python, gestion des états asynchrones.",
            "Tests unitaires Jest et déploiement continu via pipeline GitLab CI.",
            "Méthodes Agile (daily, sprint planning).",
          ].map(item => (
            <li class="flex gap-3 text-sm text-gray-400 leading-relaxed">
              <span class="text-sky-400 mt-1 shrink-0 text-xs">▸</span>
              {item}
            </li>
          ))}
        </ul>

        <div class="flex flex-wrap gap-1.5">
          {["React.js", "FastAPI", "Python", "GitLab CI", "Jest", "Agile"].map(t => (
            <span class="tech-tag">{t}</span>
          ))}
        </div>
      </div>
    </section>

    <!-- ── FORMATION ── -->
    <section>
      <h2 class="section-heading">Formation</h2>

      <div class="space-y-4">

        <!-- ISTY -->
        <div class="card card-indigo">
          <div class="flex flex-wrap items-start justify-between gap-4 mb-3">
            <div>
              <h3 class="font-bold text-white">Cycle Ingénieur Informatique — Bac+4</h3>
              <p class="text-indigo-400 text-sm font-medium mt-1">ISTY Paris-Saclay</p>
            </div>
            <span class="mono text-xs text-gray-500 bg-white/5 px-3 py-1.5 rounded-full whitespace-nowrap">
              2024 – présent
            </span>
          </div>
          <div class="flex flex-wrap gap-1.5">
            {["Algorithmique", "Systèmes d'Exploitation", "Architecture", "DevOps"].map(t => (
              <span class="tag">{t}</span>
            ))}
          </div>
        </div>

        <!-- CPGE -->
        <div class="card">
          <div class="flex flex-wrap items-start justify-between gap-4 mb-3">
            <div>
              <h3 class="font-bold text-white">CPGE</h3>
            </div>
            <span class="mono text-xs text-gray-500 bg-white/5 px-3 py-1.5 rounded-full whitespace-nowrap">
              2022 – 2024
            </span>
          </div>
          <div class="flex flex-wrap gap-1.5">
            {["Mathématiques", "Physique-Chimie", "Informatique"].map(t => (
              <span class="tag">{t}</span>
            ))}
          </div>
        </div>

      </div>
    </section>

  </div>
</Layout>

<style>
  .section-heading {
    font-size: 0.7rem;
    font-family: "JetBrains Mono", monospace;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #38bdf8;
    margin-bottom: 1.5rem;
  }
</style>
