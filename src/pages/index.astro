---
import Layout from "../layouts/Layout.astro";

const skills = [
  { icon: "⚡", title: "Langages",
    items: ["C", "C++", "Java", "Python", "JavaScript", "TypeScript", "Bash"] },
  { icon: "☁️", title: "Cloud & IaC",
    items: ["AWS EC2", "S3", "RDS", "ECR", "CloudFront", "VPC", "IAM", "Terraform"] },
  { icon: "🐳", title: "Conteneurs & CI/CD",
    items: ["Docker", "Kubernetes", "GitHub Actions", "GitLab CI"] },
  { icon: "📊", title: "Observabilité SRE",
    items: ["Prometheus", "Grafana"] },
  { icon: "🔧", title: "Dev & Data",
    items: ["FastAPI", "PostgreSQL", "Redis", "Celery"] },
  { icon: "🎨", title: "Frontend",
    items: ["React", "Node.js", "HTML5/CSS3"] },
];

const projects = [
  {
    title: "DataPulse",
    subtitle: "Pipeline ETL, NLP & Infrastructure Cloud",
    desc: "Plateforme ETL avec API FastAPI, analyse de sentiment BERT/HuggingFace via Celery/Redis, infrastructure AWS provisionnée avec Terraform (19 ressources), CI/CD avec scan sécurité Trivy et monitoring Prometheus/Grafana.",
    stack: ["FastAPI", "Celery", "Docker", "Terraform", "AWS", "Prometheus"],
    href: "https://github.com/Wisdomuzochi/datapulse",
  },
  {
    title: "react-devops-aws",
    subtitle: "Déploiement Serverless React",
    desc: "SPA React déployée sur AWS S3 + CloudFront CDN (HTTPS). Pipeline GitHub Actions avec invalidation cache automatique à chaque push sur main.",
    stack: ["React", "AWS S3", "CloudFront", "GitHub Actions"],
    href: "https://github.com/Wisdomuzochi/react-devops-aws",
  },
  {
    title: "fastapi-devops-aws",
    subtitle: "API REST & Pipeline CI/CD",
    desc: "API FastAPI conteneurisée Docker, livrée sur AWS ECR via GitHub Actions. IAM least-privilege et traçabilité image↔commit via SHA Git.",
    stack: ["FastAPI", "Docker", "AWS ECR", "GitHub Actions"],
    href: "https://github.com/Wisdomuzochi/fastapi-devops-aws",
  },
];

const gh = "https://github.com/Wisdomuzochi";
const li = "https://www.linkedin.com/in/wisdom-muonaka-45781b321";
---

<Layout title="Wisdom MUONAKA — Ingénieur DevOps">

  <!-- ── HERO ── -->
  <section class="min-h-[calc(100vh-4rem)] flex items-center justify-center px-6 py-24">
    <div class="text-center max-w-3xl w-full">

      <p class="label mb-8 fade-up">Ingénieur DevOps · Cloud · SRE</p>

      <!-- Name — equal visual weight -->
      <div class="mb-8 fade-up d1">
        <h1 class="name-line gradient-shift">MUONAKA</h1>
        <h1 class="name-line text-white">wisdom</h1>
      </div>

      <!-- Availability badge -->
      <div class="inline-flex items-center gap-2.5 border border-sky-400/30 bg-sky-400/10 text-sky-400 text-sm px-5 py-2.5 rounded-full mb-12 fade-up d2">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute h-full w-full rounded-full bg-sky-400 opacity-75"></span>
          <span class="relative h-2 w-2 rounded-full bg-sky-400"></span>
        </span>
        Disponible pour un stage / alternance
      </div>

      <!-- CTAs -->
      <div class="flex flex-wrap gap-3 justify-center fade-up d3">
        <a href={gh} target="_blank" rel="noopener" class="btn btn-secondary">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
          </svg>
          GitHub
        </a>
        <a href={li} target="_blank" rel="noopener" class="btn btn-primary">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          LinkedIn
        </a>
        <a href="/contact" class="btn btn-ghost">Me contacter →</a>
      </div>
    </div>
  </section>

  <!-- ── COMPÉTENCES ── -->
  <section class="py-20 px-6 bg-[#0d1220]">
    <div class="max-w-5xl mx-auto">

      <!-- Compétences techniques -->
      <h2 class="label mb-8">Compétences techniques</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-12">
        {[
          { icon: "⚡", title: "Langages",
            items: ["C", "C++", "Java", "Python", "JavaScript/TypeScript", "Shell/Bash"] },
          { icon: "🌐", title: "Dev Web & Backend",
            items: ["React", "Node.js", "FastAPI", "REST APIs"] },
          { icon: "☁️", title: "Cloud & AWS",
            items: ["EC2", "S3", "RDS", "ECR", "CloudFront", "VPC", "IAM"] },
          { icon: "🐳", title: "DevOps & CI/CD",
            items: ["Docker", "Kubernetes", "Terraform", "GitHub Actions", "GitLab CI"] },
          { icon: "📊", title: "Observabilité (SRE)",
            items: ["Prometheus", "Grafana"] },
          { icon: "🖥️", title: "Systèmes & OS",
            items: ["Linux (Ubuntu)", "OpenMP", "MPI"] },
        ].map(s => (
          <div class="skill-card">
            <div class="flex items-center gap-2.5 mb-3">
              <span class="text-base">{s.icon}</span>
              <span class="text-sm font-semibold text-white">{s.title}</span>
            </div>
            <div class="flex flex-wrap gap-1.5">
              {s.items.map(item => <span class="tag">{item}</span>)}
            </div>
          </div>
        ))}
      </div>

      <!-- Langues -->
      <div class="skill-card mb-4 sm:max-w-xs">
        <div class="flex items-center gap-2.5 mb-3">
          <span class="text-base">🌍</span>
          <span class="text-sm font-semibold text-white">Langues</span>
        </div>
        <div class="flex flex-wrap gap-1.5">
          {["Français (natif)", "Anglais B2 — TOEIC"].map(item => (
            <span class="tag">{item}</span>
          ))}
        </div>
      </div>

      <!-- Soft skills -->
      <div class="skill-card sm:max-w-xs">
        <div class="flex items-center gap-2.5 mb-3">
          <span class="text-base">🤝</span>
          <span class="text-sm font-semibold text-white">Soft skills</span>
        </div>
        <div class="flex flex-wrap gap-1.5">
          {["Autonome", "Dynamique", "Curieux", "Esprit d'analyse"].map(item => (
            <span class="tag">{item}</span>
          ))}
        </div>
      </div>

    </div>
  </section>

</Layout>

<style>
  /* ── Skill cards ── */
  .skill-card {
    background: #111827;
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 0.875rem;
    padding: 1.25rem;
    transition: border-color 0.2s, transform 0.2s;
  }
  .skill-card:hover {
    border-color: rgba(56,189,248,0.28);
    transform: translateY(-2px);
  }

  /* ── Hero name — equal size, equal weight ── */
  .name-line {
    display: block;
    font-size: clamp(3.5rem, 12vw, 7rem);
    font-weight: 900;
    line-height: 0.92;
    letter-spacing: -0.03em;
  }

  /* ── Section headings ── */
  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2rem;
  }
  .section-title {
    font-size: 1.125rem;
    font-weight: 700;
    color: white;
  }
  .section-link {
    font-size: 0.8125rem;
    color: #6b7280;
    transition: color 0.15s;
    text-decoration: none;
  }
  .section-link:hover { color: #38bdf8; }

  /* ── Projects — colonne sur mobile, ligne sur desktop ── */
  .projects-row {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  @media (min-width: 768px) {
    .projects-row {
      flex-direction: row;
      align-items: stretch; /* toutes les cards à la même hauteur */
    }
  }

  /* ── Project cards ── */
  .proj-card {
    display: flex;
    flex-direction: column;
    flex: 1;          /* largeur égale entre les 3 cards */
    min-width: 0;     /* empêche le débordement */
    background: #111827;
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 0.875rem;
    padding: 1.25rem;
    transition: border-color 0.2s, transform 0.2s;
  }
  .proj-card:hover {
    border-color: rgba(56,189,248,0.28);
    transform: translateY(-2px);
  }
</style>
