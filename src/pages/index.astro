---
---
<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Wisdom MUONAKA — Ingénieur DevOps</title>
    <meta name="description" content="Portfolio de Wisdom MUONAKA — Étudiant ingénieur DevOps à l'ISTY Paris-Saclay" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;900&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet" />
  </head>

  <body class="bg-[#0f1117] text-white antialiased" style="font-family: 'Inter', sans-serif;">

    <!-- ── NAV ── -->
    <nav class="fixed top-0 w-full z-50 bg-[#0f1117]/80 backdrop-blur-md border-b border-white/5">
      <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
        <span class="font-black text-lg bg-gradient-to-r from-[#38bdf8] to-[#818cf8] bg-clip-text text-transparent tracking-tight">
          WM.
        </span>
        <div class="hidden md:flex items-center gap-8 text-sm text-gray-400">
          <a href="#about"    class="hover:text-white transition-colors duration-200">À propos</a>
          <a href="#skills"   class="hover:text-white transition-colors duration-200">Compétences</a>
          <a href="#projects" class="hover:text-white transition-colors duration-200">Projets</a>
          <a href="#parcours" class="hover:text-white transition-colors duration-200">Parcours</a>
          <a href="#contact"  class="hover:text-white transition-colors duration-200">Contact</a>
        </div>
        <!-- Mobile menu toggle (visual only) -->
        <div class="md:hidden flex flex-col gap-1 cursor-pointer">
          <span class="w-5 h-px bg-gray-400"></span>
          <span class="w-5 h-px bg-gray-400"></span>
          <span class="w-5 h-px bg-gray-400"></span>
        </div>
      </div>
    </nav>

    <!-- ── HERO ── -->
    <section class="min-h-screen flex items-center justify-center pt-16 px-6">
      <div class="text-center fade-in">
        <p class="text-sm text-gray-500 tracking-[0.3em] uppercase mb-4" style="font-family: 'JetBrains Mono', monospace;">
          Ingénieur DevOps · Cloud · SRE
        </p>
        <h1 class="text-7xl sm:text-8xl md:text-[10rem] font-black tracking-tighter leading-none bg-gradient-to-r from-[#38bdf8] via-[#818cf8] to-[#38bdf8] bg-clip-text text-transparent mb-3 bg-[length:200%_auto] animate-gradient">
          MUONAKA
        </h1>
        <p class="text-3xl sm:text-4xl md:text-5xl font-light text-white/90 mb-8">
          Wisdom
        </p>
        <div class="inline-flex items-center gap-2.5 bg-[#38bdf8]/10 border border-[#38bdf8]/25 text-[#38bdf8] text-sm px-5 py-2.5 rounded-full mb-12">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#38bdf8] opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-[#38bdf8]"></span>
          </span>
          Disponible pour un stage / alternance
        </div>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="https://github.com/Wisdomuzochi"
             target="_blank" rel="noopener noreferrer"
             class="group inline-flex items-center gap-3 bg-white/5 hover:bg-white/10 border border-white/10 hover:border-white/25 px-6 py-3 rounded-xl transition-all duration-200 font-medium">
            <svg class="w-5 h-5 group-hover:scale-110 transition-transform" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
            </svg>
            GitHub
          </a>
          <a href="https://www.linkedin.com/in/wisdom-muonaka-45781b321"
             target="_blank" rel="noopener noreferrer"
             class="group inline-flex items-center gap-3 bg-[#38bdf8]/10 hover:bg-[#38bdf8]/20 border border-[#38bdf8]/30 hover:border-[#38bdf8]/60 text-[#38bdf8] px-6 py-3 rounded-xl transition-all duration-200 font-medium">
            <svg class="w-5 h-5 group-hover:scale-110 transition-transform" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            LinkedIn
          </a>
        </div>
      </div>
    </section>

    <!-- ── À PROPOS ── -->
    <section id="about" class="py-24 px-6">
      <div class="max-w-5xl mx-auto">
        <h2 class="section-title">À propos</h2>
        <div class="grid md:grid-cols-2 gap-6 mt-12">
          <div class="card card-blue">
            <p class="text-gray-300 leading-relaxed text-[15px]">
              Passionné par l'intersection entre le développement logiciel, l'infrastructure et l'architecture systèmes, je construis des systèmes fiables, scalables et observables. Mon approche est orientée SRE : automatiser, mesurer, optimiser et améliorer en continu.
            </p>
          </div>
          <div class="card card-indigo">
            <p class="text-gray-300 leading-relaxed text-[15px]">
              Étudiant ingénieur à l'ISTY Paris-Saclay (Bac+4), j'ai un attrait profond pour le DevOps, le Cloud et l'ingénierie systèmes. Je combine une solide formation en informatique avec une pratique intensive des outils DevOps modernes — de Terraform à Prometheus en passant par les pipelines CI/CD.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ── COMPÉTENCES ── -->
    <section id="skills" class="py-24 px-6 bg-white/[0.015]">
      <div class="max-w-6xl mx-auto">
        <h2 class="section-title">Compétences</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mt-12">

          {[
            { icon: "⚡", title: "Langages", color: "blue",
              skills: ["C", "C++", "Java", "Python", "JavaScript", "TypeScript", "Shell/Bash"] },
            { icon: "☁️", title: "Cloud & IaC", color: "blue",
              skills: ["AWS EC2", "S3", "RDS", "ECR", "CloudFront", "VPC", "IAM", "Terraform"] },
            { icon: "🐳", title: "Conteneurs & CI/CD", color: "indigo",
              skills: ["Docker", "Kubernetes", "GitHub Actions", "GitLab CI"] },
            { icon: "📊", title: "Observabilité SRE", color: "indigo",
              skills: ["Prometheus", "Grafana"] },
            { icon: "🔧", title: "Dev & Data", color: "blue",
              skills: ["FastAPI", "PostgreSQL", "Redis", "Celery"] },
            { icon: "🎨", title: "Frontend", color: "indigo",
              skills: ["React", "Node.js", "HTML5/CSS3"] },
          ].map(({ icon, title, color, skills }) => (
            <div class={`skill-card skill-card-${color}`}>
              <div class="flex items-center gap-3 mb-4">
                <span class="text-xl">{icon}</span>
                <h3 class="font-semibold text-white text-[15px]">{title}</h3>
              </div>
              <div class="flex flex-wrap gap-2">
                {skills.map(s => (
                  <span class="skill-tag">{s}</span>
                ))}
              </div>
            </div>
          ))}

        </div>
      </div>
    </section>

    <!-- ── PROJETS ── -->
    <section id="projects" class="py-24 px-6">
      <div class="max-w-6xl mx-auto">
        <h2 class="section-title">Projets</h2>
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mt-12">

          <!-- DataPulse — featured -->
          <div class="lg:col-span-2 project-card project-card-featured">
            <div class="flex items-start justify-between mb-4 flex-wrap gap-3">
              <div>
                <span class="text-xs text-[#38bdf8] font-mono tracking-wider uppercase bg-[#38bdf8]/10 px-2 py-1 rounded mb-2 inline-block">
                  Featured Project
                </span>
                <h3 class="text-xl font-bold text-white">DataPulse</h3>
              </div>
              <a href="https://github.com/Wisdomuzochi/datapulse"
                 target="_blank" rel="noopener noreferrer"
                 class="inline-flex items-center gap-2 text-sm text-gray-400 hover:text-[#38bdf8] transition-colors border border-white/10 hover:border-[#38bdf8]/40 px-3 py-1.5 rounded-lg">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
                </svg>
                Voir le code
              </a>
            </div>
            <p class="text-gray-400 text-sm leading-relaxed mb-5">
              Pipeline ETL + NLP multilingue (BERT/HuggingFace) avec infrastructure AWS entièrement provisionnée via Terraform (19 ressources). CI/CD automatisé, monitoring Prometheus/Grafana en production.
            </p>
            <div class="flex flex-wrap gap-2">
              {["FastAPI", "Celery", "Redis", "PostgreSQL", "Docker", "Terraform", "AWS", "Prometheus", "Grafana", "BERT"].map(t => (
                <span class="tech-tag">{t}</span>
              ))}
            </div>
          </div>

          <!-- react-devops-aws -->
          <div class="project-card">
            <div class="flex items-start justify-between mb-4 flex-wrap gap-2">
              <h3 class="text-lg font-bold text-white">react-devops-aws</h3>
              <a href="https://github.com/Wisdomuzochi/react-devops-aws"
                 target="_blank" rel="noopener noreferrer"
                 class="text-gray-500 hover:text-[#38bdf8] transition-colors">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
                </svg>
              </a>
            </div>
            <p class="text-gray-400 text-sm leading-relaxed mb-5">
              SPA React déployée sur S3 + CloudFront CDN (HTTPS). Pipeline GitHub Actions avec invalidation cache automatique à chaque push.
            </p>
            <div class="flex flex-wrap gap-2">
              {["React", "AWS S3", "CloudFront", "GitHub Actions"].map(t => (
                <span class="tech-tag">{t}</span>
              ))}
            </div>
          </div>

          <!-- fastapi-devops-aws -->
          <div class="project-card lg:col-start-2">
            <div class="flex items-start justify-between mb-4 flex-wrap gap-2">
              <h3 class="text-lg font-bold text-white">fastapi-devops-aws</h3>
              <a href="https://github.com/Wisdomuzochi/fastapi-devops-aws"
                 target="_blank" rel="noopener noreferrer"
                 class="text-gray-500 hover:text-[#38bdf8] transition-colors">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
                </svg>
              </a>
            </div>
            <p class="text-gray-400 text-sm leading-relaxed mb-5">
              API FastAPI conteneurisée Docker et livrée sur AWS ECR. IAM least-privilege, traçabilité image↔commit via SHA Git.
            </p>
            <div class="flex flex-wrap gap-2">
              {["FastAPI", "Docker", "AWS ECR", "GitHub Actions"].map(t => (
                <span class="tech-tag">{t}</span>
              ))}
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ── PARCOURS ── -->
    <section id="parcours" class="py-24 px-6 bg-white/[0.015]">
      <div class="max-w-4xl mx-auto">
        <h2 class="section-title">Parcours</h2>
        <div class="mt-12 space-y-0">

          <!-- Stage VBN-IT -->
          <div class="timeline-item">
            <div class="timeline-dot bg-[#38bdf8]"></div>
            <div class="card card-blue ml-8">
              <div class="flex flex-wrap items-start justify-between gap-3 mb-3">
                <div>
                  <h3 class="font-bold text-white">Stage Développeur Full-Stack</h3>
                  <p class="text-[#38bdf8] text-sm font-medium mt-0.5">VBN-IT, Paris</p>
                </div>
                <span class="text-xs text-gray-500 font-mono bg-white/5 px-3 py-1 rounded-full">Juin – Août 2025</span>
              </div>
              <div class="flex flex-wrap gap-2">
                {["React.js", "FastAPI", "GitLab CI", "Agile"].map(t => (
                  <span class="skill-tag">{t}</span>
                ))}
              </div>
            </div>
          </div>

          <!-- ISTY -->
          <div class="timeline-item">
            <div class="timeline-dot bg-[#818cf8]"></div>
            <div class="card card-indigo ml-8">
              <div class="flex flex-wrap items-start justify-between gap-3">
                <div>
                  <h3 class="font-bold text-white">Cycle Ingénieur Informatique — Bac+4</h3>
                  <p class="text-[#818cf8] text-sm font-medium mt-0.5">ISTY Paris-Saclay</p>
                </div>
                <span class="text-xs text-gray-500 font-mono bg-white/5 px-3 py-1 rounded-full">2024 – présent</span>
              </div>
            </div>
          </div>

          <!-- CPGE -->
          <div class="timeline-item border-l-0">
            <div class="timeline-dot bg-gray-600"></div>
            <div class="card ml-8">
              <div class="flex flex-wrap items-start justify-between gap-3">
                <div>
                  <h3 class="font-bold text-white">CPGE — Classes Préparatoires</h3>
                  <p class="text-gray-400 text-sm font-medium mt-0.5">Sup'Management, Libreville, Gabon</p>
                </div>
                <span class="text-xs text-gray-500 font-mono bg-white/5 px-3 py-1 rounded-full">2022 – 2024</span>
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ── CONTACT ── -->
    <section id="contact" class="py-24 px-6">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="section-title justify-center">Contact</h2>
        <p class="text-gray-400 mt-4 mb-12 text-[15px]">
          Disponible pour un stage ou une alternance en DevOps / Cloud.<br />
          N'hésitez pas à me contacter.
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">

          <a href="mailto:uzochiwisdom72@gmail.com"
             class="contact-card group">
            <svg class="w-6 h-6 text-[#38bdf8] group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
            </svg>
            <span class="text-sm font-medium text-white mt-3">Email</span>
            <span class="text-xs text-gray-500 mt-1 break-all">uzochiwisdom72@gmail.com</span>
          </a>

          <a href="https://www.linkedin.com/in/wisdom-muonaka-45781b321"
             target="_blank" rel="noopener noreferrer"
             class="contact-card group">
            <svg class="w-6 h-6 text-[#38bdf8] group-hover:scale-110 transition-transform" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            <span class="text-sm font-medium text-white mt-3">LinkedIn</span>
            <span class="text-xs text-gray-500 mt-1">wisdom-muonaka</span>
          </a>

          <a href="https://github.com/Wisdomuzochi"
             target="_blank" rel="noopener noreferrer"
             class="contact-card group">
            <svg class="w-6 h-6 text-[#38bdf8] group-hover:scale-110 transition-transform" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
            </svg>
            <span class="text-sm font-medium text-white mt-3">GitHub</span>
            <span class="text-xs text-gray-500 mt-1">Wisdomuzochi</span>
          </a>

        </div>
      </div>
    </section>

    <!-- ── FOOTER ── -->
    <footer class="border-t border-white/5 py-8 px-6 text-center text-gray-600 text-sm" style="font-family: 'JetBrains Mono', monospace;">
      <p>© 2025 Wisdom MUONAKA · Construit avec Astro + Tailwind</p>
    </footer>

  </body>
</html>

<style>
  /* ── Animations ── */
